{
  "mcpServers": {
    "honcho": {
      "command": "npx",
      "args": [
        "-y",
        "mcp-remote",
        "http://localhost:8787",
        "--header",
        "Authorization:${AUTH_HEADER}",
        "--header",
        "X-Honcho-User-Name:${USER_NAME}"
      ],
      "env": {
        "AUTH_HEADER": "Bearer local-dev",
        "USER_NAME": "your-peer-id"
      }
    },
    "graphify": {
      "command": "/path/from/graphify-out/.graphify_python",
      "args": [
        "-m",
        "graphify.serve",
        "/absolute/path/to/repo/graphify-out/graph.json"
      ],
      "description": "Graphify Knowledge Graph MCP Server (run graphify update . first)."
    }
  }
}
